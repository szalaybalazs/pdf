{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["react", "react-dom", "node"],
    "noEmit": true
  },
  "include": ["renderer/src/**/*.ts", "renderer/src/**/*.tsx", "src/trpc.ts"]
}
