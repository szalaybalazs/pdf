# Copy to .env and fill in. .env is read automatically.
# In the desktop app you can also set these keys in Settings (gear icon); keys set
# there are stored encrypted under the app data dir and override these.
OPENAI_API_KEY=sk-...
# Needed only if you pick the Anthropic (Opus) model in the UI. Embeddings always
# use OpenAI, so OPENAI_API_KEY is required either way.
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter (optional): if set, chat & vision for ALL models (GPT and Claude)
# route through OpenRouter's OpenAI-compatible endpoint with this one key. The
# direct ANTHROPIC_API_KEY is then unused. OpenRouter has no embeddings endpoint,
# so OPENAI_API_KEY is STILL required for the PDF index and thread search.
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# USE_OPENROUTER=true          # force on/off; defaults to on whenever the key is set

# Optional overrides (defaults shown):
# PDF_DIR=/Users/balazs/Downloads/Proba
# EMBED_MODEL=text-embedding-3-small
# VISION_MODEL=gpt-4o
# OPENAI_FRONTIER_MODEL=gpt-5.5  # frontier multimodal model, the 2nd OpenAI option in the picker
# SUMMARY_MODEL=gpt-4o-mini    # small model used to summarise chats into thread titles
# ANTHROPIC_MODEL=claude-opus-4-8
# ANSWER_MODEL=openai          # which model is selected by default: openai | anthropic
# RENDER_DPI=150
# TOP_K=8
# MAX_IMAGES=4
# PDF_QA_DATA_DIR=...          # root for index + threads.db (desktop app sets this to userData)
# INDEX_DIR=...                # override just the index location
# PDF_QA_DB=...                # override just the threads.db location
