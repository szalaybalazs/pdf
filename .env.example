# Copy to .env and fill in. .env is read automatically.
OPENAI_API_KEY=sk-...
# Needed only if you pick the Anthropic (Opus) model in the UI. Embeddings always
# use OpenAI, so OPENAI_API_KEY is required either way.
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides (defaults shown):
# PDF_DIR=/Users/balazs/Downloads/Proba
# EMBED_MODEL=text-embedding-3-small
# VISION_MODEL=gpt-4o
# ANTHROPIC_MODEL=claude-opus-4-8
# ANSWER_MODEL=openai          # which model is selected by default: openai | anthropic
# RENDER_DPI=150
# TOP_K=8
# MAX_IMAGES=4
