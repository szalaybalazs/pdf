# macOS signing + notarization env for local `npm run publish`.
#
# Copy to ../.signing/mac.env (which is git-ignored) and fill in, then:
#     set -a && source ../.signing/mac.env && set +a
#     npm run build:backend && npm run publish
#
# Locally, electron-builder auto-discovers the "Developer ID Application"
# identity from your login keychain, so CSC_LINK is optional here — the Apple
# notarization vars below are the ones you must set. (CI uses the base64
# CSC_LINK / MAC_CSC_* GitHub secrets instead; see BUILD.md.)

# --- notarization (required) ---
APPLE_ID=you@example.com
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx   # appleid.apple.com → App-Specific Passwords
APPLE_TEAM_ID=ABCDE12345                          # 10-char Team ID

# --- signing identity (optional locally if the cert is in your keychain) ---
# CSC_LINK=/absolute/path/to/DeveloperIDApplication.p12
# CSC_KEY_PASSWORD=the-p12-password
